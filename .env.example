SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite by default, Postgres for production)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3
DB_ENGINE=django.db.backends.postgresql
DB_NAME= "postgres"
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_HOST="localhost"
DB_PORT="5432"

# POSTGRES_DATABASE = "test_wacpro"
# POSTGRES_HOST = "localhost"
# POSTGRES_PORT = "5432"
# POSTGRES_USER = "postgres"
# POSTGRES_PASSWORD = "postgres"

# Instagram / Facebook / Meta API
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:8000/platforms/instagram/callback/

# Twitter / X API
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_REDIRECT_URI=http://localhost:8000/platforms/twitter/callback/

# WhatsApp Business API (uses Meta Graph API)
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
